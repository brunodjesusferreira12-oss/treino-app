# Public Supabase URL, without /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Use the publishable key or legacy anon key. Never use service_role here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ou_anon_key

# Optional: enables Fortynex Coach with OpenAI Responses API.
OPENAI_API_KEY=

# Optional: default model for the coach. Example: gpt-5
OPENAI_MODEL=gpt-5
